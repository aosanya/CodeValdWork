# CodeValdWork — environment configuration example.
# Copy this file to .env and fill in the values for your environment.
# The .env file is gitignored and must never be committed.

# -------------------------------------------------------------------
# CodeValdCross integration
# -------------------------------------------------------------------

# gRPC address of the CodeValdCross orchestrator.
# When set, CodeValdWork calls Register on startup to announce itself.
# Leave unset to run CodeValdWork in standalone mode (no registration).
# CROSS_GRPC_ADDR=:50052

# How often CodeValdWork re-registers with CodeValdCross (heartbeat).
# Accepts Go duration strings (e.g. 30s, 1m). Set to 0 to disable.
# CROSS_PING_INTERVAL=10s

# Per-RPC timeout for each Register call sent to CodeValdCross.
# CROSS_PING_TIMEOUT=5s

# Address that CodeValdCross will use to dial back into this service.
# Defaults to ":${CODEVALDWORK_PORT}". Override when the listen address is
# not directly reachable by CodeValdCross (e.g. in multi-host deployments).
# WORK_GRPC_ADVERTISE_ADDR=:50053

# Agency this CodeValdWork instance is scoped to.
# Included in every Register heartbeat sent to CodeValdCross so the
# registry can identify which agency each instance serves.
# Leave unset for instances that serve all agencies.
# CODEVALDWORK_AGENCY_ID=agency-123

# -------------------------------------------------------------------
# Inbound gRPC server
# -------------------------------------------------------------------

# TCP port the CodeValdWork gRPC server listens on.
# REQUIRED: This must be set. Use root .env for consistent port allocation.
CODEVALDWORK_PORT=50053

# Storage backend to use. Currently only "arangodb" is supported.
# CODEVALDWORK_BACKEND=arangodb

# -------------------------------------------------------------------
# ArangoDB backend
# Required — CodeValdWork uses ArangoDB as its persistence layer.
# -------------------------------------------------------------------

# ArangoDB server endpoint.
# WORK_ARANGO_ENDPOINT=http://localhost:8529

# Database name that holds the work_tasks collection.
# WORK_ARANGO_DATABASE=codevaldwork

# Database used exclusively by integration tests (make test-arango).
# A single persistent database is shared across all test runs; tests use
# unique agency IDs per run to avoid inter-test data pollution.
# WORK_ARANGO_DATABASE_TEST=codevald_tests

# ArangoDB credentials.
# WORK_ARANGO_USER=root
# WORK_ARANGO_PASSWORD=
